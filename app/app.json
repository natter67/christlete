{
  "expo": {
    "name": "Christlete",
    "slug": "christlete",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.christlete.app",
      "buildNumber": "1",
      "usesAppleSignIn": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Christlete to access your camera for profile photos.",
        "NSPhotoLibraryUsageDescription": "Allow Christlete to access your photos for profile pictures."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.christlete.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "christlete",
    "extra": {
      "eas": {
        "projectId": "christlete-app"
      }
    }
  }
}
